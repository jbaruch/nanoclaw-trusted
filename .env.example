# CI reviewer secrets for the jbaruch/coding-policy gh-aw PR review workflows.
# These are GitHub Actions repository secrets — set them at:
# https://github.com/jbaruch/nanoclaw-trusted/settings/secrets/actions
#
# The OpenAI-family (Codex) reviewer accepts either CODEX_API_KEY or OPENAI_API_KEY
# (CODEX_API_KEY takes precedence).

# OpenAI / Codex reviewer credential
CODEX_API_KEY=
OPENAI_API_KEY=
# Anthropic (Claude) reviewer credential
ANTHROPIC_API_KEY=
# Tessl registry token for the reviewer's `tessl install jbaruch/coding-policy` step
# Generate at https://tessl.io/account/api-keys
TESSL_TOKEN=
